# ================= Sentinel environment =================
# Copy to .env and fill real values. NEVER commit .env.
# config.py (pydantic-settings) is the ONLY code that reads these.

# --- LLM (Groq) ---
GROQ_API_KEY=                      # console.groq.com -> API Keys (free tier)
GROQ_MODEL_SIMPLE=llama-3.1-8b-instant
GROQ_MODEL_COMPLEX=llama-3.3-70b-versatile

# --- RAG / index ---
EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
INDEX_DIR=index                    # local dir holding faiss.index / bm25.pkl / chunks.jsonl
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
TOP_K=8                            # chunks handed to synthesizer
CANDIDATES_PER_RETRIEVER=20        # top-N from dense and sparse before RRF
RRF_K=60

# --- agent budgets (hard caps) ---
TOKEN_BUDGET=10000                 # max LLM tokens per request
DEADLINE_SECONDS=20                # wall-clock cap per request
MAX_ATTEMPTS=2                     # repair attempts before refusal

# --- AWS (unused until P4; keep empty locally) ---
AWS_REGION=ap-south-1
S3_BUCKET_DOCS=                    # sentinel-docs-<acct-id>
DDB_TABLE_USERS=sentinel-users
DDB_TABLE_QUOTAS=sentinel-quotas
DDB_TABLE_TRACES=sentinel-traces
USE_S3_INDEX=false                 # true in Lambda: pull index/ from S3 at cold start
